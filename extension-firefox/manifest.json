{
  "manifest_version": 2,
  "name": "Claude → Gemini Bridge",
  "version": "2.0",
  "description": "Multi-channel bridge between Claude Code and Gemini (Firefox)",
  "browser_specific_settings": {
    "gecko": {
      "id": "claude-gemini-bridge@local",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "alarms",
    "tabs",
    "storage",
    "http://127.0.0.1:52945/*",
    "https://gemini.google.com/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon.png"
    }
  }
}
